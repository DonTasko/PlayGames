<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Slots Demo — DonTasko</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #111118;
    --card: #16161f;
    --border: #2a2a3a;
    --gold: #f0c040;
    --gold2: #e8a820;
    --red: #e84040;
    --text: #e8e8f0;
    --muted: #6a6a88;
    --radius: 12px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ---- HEADER ---- */
  header {
    background: linear-gradient(180deg, #0f0f1a 0%, transparent 100%);
    padding: 0 2rem;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 64px;
  }

  .logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.8rem;
    letter-spacing: 2px;
    color: var(--gold);
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo span { color: var(--text); }

  .search-wrap {
    flex: 1;
    max-width: 400px;
    position: relative;
  }

  .search-wrap input {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem 1rem 0.5rem 2.5rem;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s;
  }
  .search-wrap input:focus { border-color: var(--gold); }
  .search-wrap .icon {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--muted);
    font-size: 0.9rem;
    pointer-events: none;
  }

  /* ---- HERO ---- */
  .hero {
    text-align: center;
    padding: 3rem 2rem 1.5rem;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, #1a1030 0%, transparent 70%);
  }

  .hero h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 6vw, 5rem);
    letter-spacing: 4px;
    line-height: 1;
    color: var(--gold);
    text-shadow: 0 0 40px rgba(240,192,64,0.3);
    margin-bottom: 0.5rem;
  }

  .hero p {
    color: var(--muted);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }

  /* ---- FILTERS ---- */
  .filters {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem 1.5rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .filter-label {
    color: var(--muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-right: 0.5rem;
  }

  .pill {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 0.35rem 1rem;
    border-radius: 999px;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.15s;
    font-family: 'DM Sans', sans-serif;
    white-space: nowrap;
  }
  .pill:hover { border-color: var(--gold); color: var(--gold); }
  .pill.active { background: var(--gold); border-color: var(--gold); color: #000; font-weight: 600; }

  /* ---- GRID ---- */
  .main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.4rem;
    letter-spacing: 2px;
    color: var(--muted);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  #games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
  }

  .game-card {
    background: var(--card);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    position: relative;
    aspect-ratio: 3/4;
    display: flex;
    flex-direction: column;
  }

  .game-card:hover {
    transform: translateY(-4px) scale(1.02);
    border-color: var(--gold);
    box-shadow: 0 8px 32px rgba(240,192,64,0.15);
  }

  .game-card img {
    width: 100%;
    height: 75%;
    object-fit: cover;
    display: block;
    background: var(--surface);
  }

  .game-card .img-placeholder {
    width: 100%;
    height: 75%;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
  }

  .game-info {
    padding: 0.6rem 0.75rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .game-name {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 0.15rem;
  }

  .game-provider {
    font-size: 0.7rem;
    color: var(--gold);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .play-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s;
    border-radius: var(--radius);
  }

  .game-card:hover .play-overlay { opacity: 1; }

  .play-btn {
    background: var(--gold);
    color: #000;
    border: none;
    border-radius: 999px;
    padding: 0.6rem 1.5rem;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* ---- MODAL ---- */
  #modal-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.92);
    z-index: 200;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  #modal-backdrop.open { display: flex; }

  #modal {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    width: 100%;
    max-width: 960px;
    height: 90vh;
    max-height: 700px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0,0,0,0.8);
  }

  #modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }

  #modal-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.3rem;
    letter-spacing: 2px;
    color: var(--gold);
  }

  #modal-subtitle {
    font-size: 0.8rem;
    color: var(--muted);
  }

  #modal-close {
    background: none;
    border: 1px solid var(--border);
    color: var(--muted);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    flex-shrink: 0;
  }
  #modal-close:hover { border-color: var(--red); color: var(--red); }

  #game-frame {
    flex: 1;
    width: 100%;
    border: none;
    display: block;
  }

  /* ---- LOADING / EMPTY ---- */
  .spinner {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem;
    gap: 1rem;
    color: var(--muted);
    flex-direction: column;
  }

  .spin {
    width: 40px;
    height: 40px;
    border: 3px solid var(--border);
    border-top-color: var(--gold);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .empty { text-align: center; padding: 4rem; color: var(--muted); }

  /* ---- PAGINATION ---- */
  .pagination {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    align-items: center;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .page-btn {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--muted);
    width: 38px;
    height: 38px;
    border-radius: 8px;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    transition: all 0.15s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .page-btn:hover, .page-btn.active { background: var(--gold); border-color: var(--gold); color: #000; font-weight: 700; }
  .page-btn:disabled { opacity: 0.3; cursor: default; }

  /* ---- AVISO ---- */
  .aviso {
    background: linear-gradient(90deg, #1a1010, #1a1318);
    border-top: 1px solid var(--border);
    padding: 1rem 2rem;
    text-align: center;
    font-size: 0.75rem;
    color: var(--muted);
  }
  .aviso a { color: var(--gold); }

  /* ---- RESPONSIVE ---- */
  @media (max-width: 600px) {
    #games-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); }
    .header-inner { gap: 1rem; }
    .search-wrap { max-width: none; }
  }
</style>
</head>
<body>

<header>
  <div class="header-inner">
    <a class="logo" href="#">🎰 <span>SLOTS</span>DEMO</a>
    <div class="search-wrap">
      <span class="icon">🔍</span>
      <input type="text" id="search-input" placeholder="Pesquisar jogo ou fornecedor...">
    </div>
  </div>
</header>

<div class="hero">
  <h1>Jogos Demo Gratuitos</h1>
  <p>Joga sem risco • Sem registo • Mais de 10.000 slots dos melhores fornecedores</p>
</div>

<div class="filters" id="provider-filters">
  <span class="filter-label">Fornecedor:</span>
  <button class="pill active" data-provider="">Todos</button>
  <button class="pill" data-provider="Pragmatic Play">Pragmatic Play</button>
  <button class="pill" data-provider="Hacksaw Gaming">Hacksaw</button>
  <button class="pill" data-provider="Amusnet">Amusnet</button>
  <button class="pill" data-provider="Play'n GO">Play'n GO</button>
  <button class="pill" data-provider="NetEnt">NetEnt</button>
  <button class="pill" data-provider="Push Gaming">Push Gaming</button>
  <button class="pill" data-provider="Nolimit City">Nolimit City</button>
  <button class="pill" data-provider="ELK Studios">ELK Studios</button>
  <button class="pill" data-provider="Relax Gaming">Relax Gaming</button>
</div>

<div class="main">
  <div class="section-title" id="results-label">A carregar jogos...</div>
  <div id="games-grid">
    <div class="spinner"><div class="spin"></div><span>A carregar jogos...</span></div>
  </div>
  <div class="pagination" id="pagination"></div>
</div>

<div class="aviso">
  ⚠️ Estes jogos são apenas para diversão (modo demo). Não envolve dinheiro real. Jogo responsável: <a href="https://www.srij.turismodeportugal.pt" target="_blank">SRIJ</a> | +18
</div>

<!-- MODAL -->
<div id="modal-backdrop">
  <div id="modal">
    <div id="modal-header">
      <div>
        <div id="modal-title">A carregar...</div>
        <div id="modal-subtitle"></div>
      </div>
      <button id="modal-close" onclick="closeModal()">✕</button>
    </div>
    <iframe id="game-frame" src="" allowfullscreen></iframe>
  </div>
</div>

<script>
const API_TOKEN = 'WvtVxS1v7zEZOFKO6iy5Zhv5QkHCG7Y9148lcuNnJMXmIryEIk';
const API_BASE  = 'https://slotslaunch.com/api';
const ORIGIN    = 'dontasko.pt';
const PER_PAGE  = 48;

let allGames    = [];
let filtered    = [];
let currentPage = 1;
let activeProvider = '';
let searchTerm  = '';

// ---- FETCH GAMES ----
async function fetchGames() {
  const headers = {
    'Content-Type': 'application/json',
    'Accept': 'application/json',
    'Origin': ORIGIN
  };

  let page = 1;
  let games = [];

  // Fetch first page to know total
  const url = `${API_BASE}/games?token=${API_TOKEN}&per_page=100&order_by=name&order=asc&page=1`;
  try {
    const res = await fetch(url, { headers });
    const data = await res.json();
    games = data.data || [];
    const lastPage = data.meta?.last_page || 1;

    // Fetch remaining pages (max 5 pages = 500 games to keep it fast)
    const maxPages = Math.min(lastPage, 5);
    const promises = [];
    for (let p = 2; p <= maxPages; p++) {
      promises.push(
        fetch(`${API_BASE}/games?token=${API_TOKEN}&per_page=100&order_by=name&order=asc&page=${p}`, { headers })
          .then(r => r.json())
          .then(d => d.data || [])
      );
    }
    const extraPages = await Promise.all(promises);
    extraPages.forEach(g => games = games.concat(g));
  } catch (err) {
    console.error('Erro ao carregar jogos:', err);
    document.getElementById('games-grid').innerHTML = `
      <div class="empty">
        <p style="font-size:2rem; margin-bottom:0.5rem">⚠️</p>
        <p>Erro ao carregar jogos. Verifica a consola.</p>
        <p style="font-size:0.75rem; margin-top:0.5rem; color:#555">${err.message}</p>
      </div>`;
    return;
  }

  allGames = games;
  applyFilters();
}

// ---- FILTERS ----
function applyFilters() {
  filtered = allGames.filter(g => {
    const matchProvider = !activeProvider || (g.provider || '').toLowerCase().includes(activeProvider.toLowerCase());
    const matchSearch   = !searchTerm || g.name.toLowerCase().includes(searchTerm) || (g.provider || '').toLowerCase().includes(searchTerm);
    return matchProvider && matchSearch;
  });
  currentPage = 1;
  renderGrid();
}

// ---- RENDER GRID ----
function renderGrid() {
  const grid  = document.getElementById('games-grid');
  const label = document.getElementById('results-label');
  const start = (currentPage - 1) * PER_PAGE;
  const slice = filtered.slice(start, start + PER_PAGE);

  label.textContent = `${filtered.length} jogos encontrados`;

  if (filtered.length === 0) {
    grid.innerHTML = '<div class="empty">Nenhum jogo encontrado. Tenta outro filtro.</div>';
    document.getElementById('pagination').innerHTML = '';
    return;
  }

  grid.innerHTML = slice.map(g => {
    const thumb = g.thumb || '';
    const name  = escHtml(g.name || 'Sem nome');
    const prov  = escHtml(g.provider || '');
    const imgTag = thumb
      ? `<img src="${escHtml(thumb)}" alt="${name}" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">`
      : '';
    const placeholder = `<div class="img-placeholder" ${thumb ? 'style="display:none"' : ''}>🎰</div>`;
    return `
      <div class="game-card" onclick="openGame(${g.id}, '${name.replace(/'/g,"\\'")}', '${prov.replace(/'/g,"\\'")}')">
        ${imgTag}${placeholder}
        <div class="game-info">
          <div class="game-name">${name}</div>
          <div class="game-provider">${prov}</div>
        </div>
        <div class="play-overlay"><button class="play-btn">▶ Jogar</button></div>
      </div>`;
  }).join('');

  renderPagination();
}

// ---- PAGINATION ----
function renderPagination() {
  const total = Math.ceil(filtered.length / PER_PAGE);
  const pg    = document.getElementById('pagination');
  if (total <= 1) { pg.innerHTML = ''; return; }

  let html = '';
  html += `<button class="page-btn" onclick="goPage(${currentPage-1})" ${currentPage===1?'disabled':''}>‹</button>`;

  for (let i = 1; i <= total; i++) {
    if (i === 1 || i === total || Math.abs(i - currentPage) <= 2) {
      html += `<button class="page-btn ${i===currentPage?'active':''}" onclick="goPage(${i})">${i}</button>`;
    } else if (Math.abs(i - currentPage) === 3) {
      html += `<span style="color:var(--muted);padding:0 4px">…</span>`;
    }
  }

  html += `<button class="page-btn" onclick="goPage(${currentPage+1})" ${currentPage===total?'disabled':''}>›</button>`;
  pg.innerHTML = html;
}

function goPage(p) {
  const total = Math.ceil(filtered.length / PER_PAGE);
  if (p < 1 || p > total) return;
  currentPage = p;
  renderGrid();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ---- OPEN GAME ----
function openGame(id, name, provider) {
  const frameUrl = `https://slotslaunch.com/iframe/${id}?token=${API_TOKEN}`;
  document.getElementById('modal-title').textContent = name;
  document.getElementById('modal-subtitle').textContent = provider;
  document.getElementById('game-frame').src = frameUrl;
  document.getElementById('modal-backdrop').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  document.getElementById('modal-backdrop').classList.remove('open');
  document.getElementById('game-frame').src = '';
  document.body.style.overflow = '';
}

document.getElementById('modal-backdrop').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

// ---- EVENTS ----
document.querySelectorAll('.pill').forEach(btn => {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
    this.classList.add('active');
    activeProvider = this.dataset.provider;
    applyFilters();
  });
});

document.getElementById('search-input').addEventListener('input', function() {
  searchTerm = this.value.toLowerCase().trim();
  applyFilters();
});

// ---- UTILS ----
function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ---- INIT ----
fetchGames();
</script>
</body>
</html>
